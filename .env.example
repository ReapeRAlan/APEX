# ============================================================
# APEX Environment Variables
# ============================================================

# ── Database ──
DATABASE_URL=postgresql://apex:CHANGE_ME@localhost:5432/apex
POSTGRES_PASSWORD=

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Google Earth Engine ──
GEE_SERVICE_ACCOUNT_EMAIL=tu-email@proyecto.iam.gserviceaccount.com
GEE_KEY_FILE=./gee_key.json
# GEE_AUTH_MODE=interactive

# ── Backend Server ──
BACKEND_PORT=8008
FRONTEND_PORT=5173
DATA_DIR=./data/tiles
DB_PATH=./db/apex.sqlite

# ── GPU ──
CUDA_VISIBLE_DEVICES=0
TORCH_DEVICE=cuda
MAX_VRAM_GB=5.5
INFERENCE_BATCH_SIZE=4

# ── NASA FIRMS ──
FIRMS_MAP_KEY=
FIRMS_SOURCES=VIIRS_SNPP_NRT,VIIRS_NOAA20_NRT,VIIRS_NOAA21_NRT

# ── Email Alerts (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=

# ── Auth (JWT) ──
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Vertex AI / Gemini ──
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro

# ── MLflow ──
MLFLOW_TRACKING_URI=http://localhost:5000